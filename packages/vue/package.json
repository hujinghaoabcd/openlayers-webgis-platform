{
  "name": "@omap/vue",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@omap/core": "workspace:*",
    "ol": "^10.9.0",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vue-tsc": "^3.0.0"
  }
}
